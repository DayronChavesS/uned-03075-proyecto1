@model PoloNorte_WEB.Models.Cliente

@{
    ViewData["Title"] = "Crear nuevo cliente";
}

<h1>Crear nuevo cliente: </h1>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" id="formulario">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <p style="color: red;"> @Html.Label("", Convert.ToString((string)ViewBag.Error)) </p>
                <label asp-for="Cedula" class="control-label" id="label_cedula"></label>
                <input asp-for="Cedula" class="form-control" id="input_cedula" placeholder="#-###-###### o 0#-####-####" pattern="[0-9]{1}-[0-9]{3}-[0-9]{6} | [0-9]{2}-[0-9]{4}-[0-9]{4}"/>
                <span asp-validation-for="Cedula" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Telefono" class="control-label"></label>
                <input asp-for="Telefono" class="form-control" id="input_telefono" placeholder="####-####"/>
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Descuento" style="display:none" id="input_descuento" /> <!-- @Html.DisplayNameFor(model => model.Descuento) -->
                    <a>Descuento: </a> <br>
                    <input type="radio" value="Si" name="false_descuento" id="input_radioSi" required>
                    <label for="Si"> Si </label><br>
                    <input type="radio" value="No" name="false_descuento" id="input_radioNo" required>
                    <label for="No"> No </label><br>
                </label>
            </div>
            <div class="form-group">
                <label asp-for="ComprasRecientes" class="control-label"></label>
                <input asp-for="ComprasRecientes" class="form-control" placeholder="# > 0"/>
                <span asp-validation-for="ComprasRecientes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ComprasUltimoAño" class="control-label"></label>
                <input asp-for="ComprasUltimoAño" class="form-control" placeholder="# > 0"/>
                <span asp-validation-for="ComprasUltimoAño" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ComprasAC" class="control-label"></label>
                <input asp-for="ComprasAC" class="form-control" placeholder="# > 0"/>
                <span asp-validation-for="ComprasAC" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Crear" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/Create.js"></script>
}
